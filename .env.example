APP_NAME="Event Visuals"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database — MySQL 8 (see README for the Docker one-liner).
# Host port 3307 is used because 3306 is often already taken (a local MySQL or
# an SSH tunnel); the container still listens on 3306 internally.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=lhp_events
DB_USERNAME=lhp
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database
QUEUE_CONNECTION=database

# Mail is logged to storage/logs/laravel.log in local dev (no real SMTP needed)
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.test"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Number of events seeded by EventSeeder. Keep small for local dev; the planted
# full dataset is 1,250,000, which Approach A is built to handle (see CLAUDE.md).
SEED_ROWS=500
